# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=gps_heatmap

# Backend - Database
DATABASE_URL=postgresql://user:password@postgres/gps_heatmap

# Backend - Redis
REDIS_URL=redis://redis:6379

# Backend - Auth
ENVIRONMENT=development
JWT_SECRET=change_me
JWT_EXPIRES_DAYS=30

# Backend - External Services
RESEND_API_KEY=
ORS_API_KEY=

# Backend - Configuration
MAX_FILE_SIZE_MB=20
NOMINATIM_USER_AGENT=gps-heatmap/1.0 (change-me@example.com)
