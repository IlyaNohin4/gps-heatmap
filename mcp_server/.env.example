# Base URL of the gps-heatmap backend API.
# When run via `docker compose --profile mcp run`, the backend is reachable
# by its service name on the compose network — keep this as-is unless you're
# running the server outside Docker.
GPS_HEATMAP_API_URL=http://backend:8000

# Long-lived JWT for your account. Get one via:
#   curl -X POST http://localhost:8000/api/auth/login \
#     -H "Content-Type: application/json" \
#     -d '{"email": "you@example.com", "password": "..."}'
# Tokens are valid for 30 days (see CLAUDE.md) — regenerate when it expires.
GPS_HEATMAP_TOKEN=
